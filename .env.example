# ============================================================
# Twilio OTP Framework — Environment Variables
# ============================================================
# Copy this to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ============================================================

# ── Twilio (Required) ───────────────────────────────────────
# Get these from https://console.twilio.com
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ── Twilio Sender (Choose one or both) ──────────────────────
# Messaging Service SID (recommended for production)
TWILIO_MESSAGING_SERVICE_SID="MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Dedicated phone number (for development or as fallback)
TWILIO_PHONE_NUMBER="+15005550006"

# Voice-specific number (optional, falls back to TWILIO_PHONE_NUMBER)
TWILIO_VOICE_NUMBER=""

# WhatsApp sender (optional)
TWILIO_WHATSAPP_NUMBER="whatsapp:+14155238886"

# ── Twilio Verify (Optional — for managed OTP) ─────────────
TWILIO_VERIFY_SERVICE_SID="VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ── Twilio Webhooks (Optional) ──────────────────────────────
TWILIO_STATUS_CALLBACK_URL="https://yourapp.com/api/twilio/webhook"

# ── OTP Security ────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
OTP_HMAC_SECRET="generate-a-random-64-char-hex-string"

# ── Database ────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# ── Redis (Rate Limiting) ──────────────────────────────────
KV_REST_API_URL="https://your-instance.upstash.io"
KV_REST_API_TOKEN="your-upstash-rest-token"

# ── Auth & Sessions ─────────────────────────────────────────
SESSION_COOKIE_NAME="__session"
SESSION_DURATION_DAYS="14"
NEXTAUTH_SECRET="generate-a-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# ── Application ─────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="Your App"
NEXT_PUBLIC_BASE_URL="https://yourapp.com"
